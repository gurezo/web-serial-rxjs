{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "outDir": "../../../dist/out-tsc",
    "moduleResolution": "bundler",
    "types": ["vite/client", "svelte"]
  },
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.svelte",
    "src/**/*.test.svelte"
  ],
  "include": ["src/**/*.js", "src/**/*.ts", "src/**/*.svelte"]
}
